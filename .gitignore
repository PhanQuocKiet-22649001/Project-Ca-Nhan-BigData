# Dependencies (Bỏ qua thư viện của cả frontend và backend)
node_modules/
backend/.env
# Environment files (Bảo mật các biến môi trường, mật khẩu database)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build output (Bỏ qua các thư mục sinh ra khi build dự án React)
dist/
build/

# Log files (Bỏ qua các file log báo lỗi của npm)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS specific files (Bỏ qua các file rác do hệ điều hành tự tạo ra)
.DS_Store
Thumbs.db